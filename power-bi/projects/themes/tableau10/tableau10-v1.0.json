{
  "$schema": "https://raw.githubusercontent.com/microsoft/powerbi-desktop-samples/main/Report%20Theme%20JSON%20Schema/reportThemeSchema-2.152.json",
  "name": "Tableau 10",
  "dataColors": [
    "#4E79A7",
    "#F28E2B",
    "#59A14F",
    "#E15759",
    "#76B7B2",
    "#EDC948",
    "#B07AA1",
    "#FF9DA7",
    "#9C755F",
    "#BAB0AC"
  ],
  "good": "#59A14F",
  "neutral": "#BAB0AC",
  "bad": "#E15759",
  "maximum": "#4E79A7",
  "center": "#EEF0F3",
  "minimum": "#E15759",
  "null": "#9AA0AA",
  "foreground": "#1A1C20",
  "foregroundNeutralSecondary": "#4D5159",
  "foregroundLight": "#7A7F88",
  "foregroundNeutralTertiary": "#9AA0AA",
  "foregroundDark": "#1A1C20",
  "background": "#FFFFFF",
  "backgroundLight": "#F7F8FA",
  "backgroundNeutral": "#EEF0F3",
  "backgroundDark": "#E2E5EA",
  "tableAccent": "#4E79A7",
  "hyperlink": "#4E79A7",
  "shapeStroke": "#E2E5EA",
  "accent": "#4E79A7",
  "textClasses": {
    "callout": {
      "color": "#1A1C20",
      "fontFace": "Segoe UI",
      "fontSize": 28
    },
    "title": {
      "color": "#1A1C20",
      "fontFace": "Segoe UI Semibold",
      "fontSize": 12
    },
    "header": {
      "color": "#1A1C20",
      "fontFace": "Segoe UI Semibold",
      "fontSize": 10
    },
    "label": {
      "color": "#4D5159",
      "fontFace": "Segoe UI",
      "fontSize": 9
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#E2E5EA"
              }
            },
            "radius": 5
          }
        ],
        "dropShadow": [
          {
            "show": false
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#1A1C20"
              }
            },
            "background": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 12,
            "alignment": "left"
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": {
              "solid": {
                "color": "#F7F8FA"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#1A1C20"
              }
            },
            "transparency": 0,
            "border": true,
            "borderColor": {
              "solid": {
                "color": "#E2E5EA"
              }
            },
            "titleSize": 13,
            "headerSize": 11,
            "fontFamily": "Segoe UI",
            "checkboxAndApplyColor": {
              "solid": {
                "color": "#4E79A7"
              }
            },
            "inputBoxColor": {
              "solid": {
                "color": "#EEF0F3"
              }
            }
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#F7F8FA"
              }
            },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#F7F8FA"
              }
            },
            "transparency": 0
          }
        ]
      }
    }
  }
}