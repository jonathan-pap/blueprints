{
  "description": "Validates PBIP project files (PBIR structure, TMDL syntax, report binding, visual field bindings) before/after Write/Edit/Bash modifications",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-visual-binding.sh\"",
            "timeout": 15,
            "if": "Bash(*pbir add visual*)"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-visual-binding.sh\"",
            "timeout": 15,
            "if": "Bash(*pbir visuals bind*)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-pbir.sh\"",
            "timeout": 10,
            "if": "Edit(**.Report/**)"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-tmdl.sh\"",
            "timeout": 10,
            "if": "Edit(**/*.tmdl)"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-report-binding.sh\"",
            "timeout": 10,
            "if": "Edit(**/definition.pbir)"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-pbir.sh\"",
            "timeout": 10,
            "if": "Write(**.Report/**)"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-tmdl.sh\"",
            "timeout": 10,
            "if": "Write(**/*.tmdl)"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-report-binding.sh\"",
            "timeout": 10,
            "if": "Write(**/definition.pbir)"
          }
        ]
      }
    ]
  }
}
